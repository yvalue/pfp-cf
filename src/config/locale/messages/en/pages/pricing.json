      "faq": {
        "id": "faq",
        "block": "faq",
        "title": "Pricing FAQ",
        "description": "Answers to common questions about plans, credits, billing cycles, and upgrades.",
        "items": [
          {
            "question": "What is included in the free experience?",
            "answer": "The free experience lets you try the core product with limited features, lower priority processing, and smaller usage limits before upgrading."
          },
          {
            "question": "What is the difference between one-time, monthly, and yearly plans?",
            "answer": "One-time plans give you a fixed package of credits for a limited validity period. Monthly and yearly plans are recurring subscriptions with ongoing credits and different billing cycles."
          },
          {
            "question": "Do credits expire?",
            "answer": "Yes. Credits follow the validity period shown on each plan. Check the plan details on the card to see how long your credits remain available."
          },
          {
            "question": "Can I switch plans later?",
            "answer": "Yes. You can upgrade when your usage grows. If you already have an active subscription, the pricing page will also indicate your current plan."
          },
          {
            "question": "Will the displayed price change when I switch billing tabs?",
            "answer": "Yes. The pricing cards update when you switch between one-time, monthly, and yearly billing so you can compare the correct price and billing unit for each option."
          },
          {
            "question": "Which payment methods are supported?",
            "answer": "Available payment methods depend on the plan and currency you choose. The supported providers are applied automatically at checkout based on the selected pricing option."
          }
        ]
      }
